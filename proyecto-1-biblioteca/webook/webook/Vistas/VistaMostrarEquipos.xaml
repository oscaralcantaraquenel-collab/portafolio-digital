<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="webook.Vistas.VistaMostrarEquipos"
             BackgroundColor="#F4E1D2">

    <ContentPage.Content>
        <StackLayout Padding="15" Spacing="15">

            <!-- Título -->
            <Label Text="Equipos Registrados"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#5A3E2B"
                   HorizontalOptions="Center"/>

            <!-- Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="15"
                   Padding="10"
                   HasShadow="True">

                <ListView x:Name="ListaEquipos"
                          SeparatorVisibility="Default"
                          RowHeight="60">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <StackLayout Padding="10" Spacing="2">

                                    <Label Text="{Binding id_equipo}"
                                           FontAttributes="Bold"
                                           TextColor="#5A3E2B"
                                           FontSize="16"/>

                                    <Label Text="{Binding Marca}"
                                           TextColor="Gray"
                                           FontSize="14"/>

                                </StackLayout>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>
            </Frame>

            <!-- Footer -->
            <Label Text="© CODAL Innovations S.A. de C.V."
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center"
                   Margin="0,10"/>

        </StackLayout>
    </ContentPage.Content>
</ContentPage>