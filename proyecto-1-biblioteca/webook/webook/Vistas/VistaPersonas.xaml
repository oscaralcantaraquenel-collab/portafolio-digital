<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="webook.Vistas.VistaPersonas"
             BackgroundColor="#F4E1D2">

    <ContentPage.Content>
        <ScrollView>
            <StackLayout Padding="15" Spacing="15">

                <!-- Título -->
                <Label Text="Registro de Personas"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#5A3E2B"
                       HorizontalOptions="Center"/>

                <!-- Card -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       Padding="20"
                       HasShadow="True">

                    <StackLayout Spacing="10">

                        <!-- Nombre -->
                        <Label Text="Nombre" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="nombre"
                               Placeholder="Nombre"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Apellido Paterno -->
                        <Label Text="Apellido Paterno" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="apellidoP"
                               Placeholder="Apellido paterno"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Apellido Materno -->
                        <Label Text="Apellido Materno" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="apellidoM"
                               Placeholder="Apellido materno"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Edad -->
                        <Label Text="Edad" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="edad"
                               Placeholder="Edad"
                               Keyboard="Numeric"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Género -->
                        <Label Text="Género" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Picker x:Name="genero"
                                Title="Selecciona el género"
                                BackgroundColor="#F5F5F5"
                                TextColor="Black">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Masculino</x:String>
                                        <x:String>Femenino</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                        </Picker>

                    </StackLayout>
                </Frame>

                <!-- Botones -->
                <StackLayout Spacing="10">

                    <Button x:Name="btnRegistrarP"
                            Text="Registrar"
                            BackgroundColor="#8B5E3C"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>

                    <Button x:Name="btnRestablecerP"
                            Text="Restablecer"
                            BackgroundColor="#D3B8A0"
                            TextColor="Black"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>

                    <Button x:Name="btnMostrarP"
                            Text="Mostrar Personas"
                            BackgroundColor="#A67C52"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>
                </StackLayout>

                <!-- Footer -->
                <Label Text="© CODAL Innovations S.A. de C.V."
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"
                       Margin="0,10"/>

            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>