<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="webook.Vistas.RegistroEspacios"
             BackgroundColor="#F4E1D2">

    <ContentPage.Content>
        <ScrollView>
            <StackLayout Padding="15" Spacing="15">

                <!-- Título -->
                <Label Text="Registro de Espacios"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="#5A3E2B"
                       HorizontalOptions="Center" />

                <!-- Card -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       Padding="20"
                       HasShadow="True">

                    <StackLayout Spacing="10">

                        <!-- Nombre -->
                        <Label Text="Nombre" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="nombre"
                               Placeholder="Nombre del espacio"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Estado -->
                        <Label Text="Estado" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="estado"
                               Placeholder="Estado del espacio"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Descripción -->
                        <Label Text="Descripción" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="descripcion"
                               Placeholder="Descripción"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Ubicación -->
                        <Label Text="Ubicación" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="ubicacion"
                               Placeholder="Ubicación del espacio"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                        <!-- Tipo -->
                        <Label Text="Tipo" FontAttributes="Bold" TextColor="#5A3E2B"/>
                        <Entry x:Name="tipo"
                               Placeholder="Tipo de espacio"
                               BackgroundColor="#F5F5F5"
                               TextColor="Black"
                               PlaceholderColor="Gray"
                               HeightRequest="45"/>

                    </StackLayout>
                </Frame>

                <!-- Botones -->
                <StackLayout Spacing="10">

                    <Button x:Name="Boton_Guardar"
                            Text="Registrar"
                            BackgroundColor="#8B5E3C"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>

                    <Button x:Name="Boton_Limpiar"
                            Text="Restablecer"
                            BackgroundColor="#D3B8A0"
                            TextColor="Black"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>

                    <Button x:Name="Boton_Registros"
                            Text="Mostrar Espacios"
                            BackgroundColor="#A67C52"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"
                            FontSize="16"/>
                </StackLayout>

                <!-- Footer -->
                <Label Text="© CODAL Innovations S.A. de C.V."
                       FontSize="12"
                       TextColor="Gray"
                       HorizontalTextAlignment="Center"
                       Margin="0,10"/>

            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>