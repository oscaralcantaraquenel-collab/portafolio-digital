<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="webook.Vistas.Vista_Consulta_Espacios"
             BackgroundColor="#F4E1D2">

    <ContentPage.Content>
        <StackLayout Padding="15" Spacing="15">

            <!-- Título -->
            <Label Text="Lista de Espacios"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#5A3E2B"
                   HorizontalOptions="Center" />

            <!-- Card -->
            <Frame BackgroundColor="White"
                   CornerRadius="15"
                   Padding="10"
                   HasShadow="True">

                <!-- Lista -->
                <ListView x:Name="ListaEspacios"
                          SeparatorVisibility="None"
                          HasUnevenRows="True">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <ViewCell>
                                <Frame BackgroundColor="#F9F9F9"
                                       CornerRadius="10"
                                       Margin="5"
                                       Padding="10"
                                       HasShadow="False">

                                    <StackLayout Spacing="5">

                                        <!-- Nombre -->
                                        <Label Text="{Binding Nombre_Espacio}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="#5A3E2B"/>

                                        <!-- ID -->
                                        <Label Text="{Binding Id_espacio, StringFormat='ID: {0}'}"
                                               FontSize="13"
                                               TextColor="Gray"/>

                                    </StackLayout>
                                </Frame>
                            </ViewCell>
                        </DataTemplate>
                    </ListView.ItemTemplate>

                </ListView>
            </Frame>

            <!-- Footer -->
            <Label Text="© CODAL Innovations S.A. de C.V."
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center"
                   Margin="0,10"/>

        </StackLayout>
    </ContentPage.Content>
</ContentPage>